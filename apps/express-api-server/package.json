{
	"name": "@pluteojs/express-api-server",
	"version": "0.0.1",
	"description": "PluteoJS Express API Server",
	"private": true,
	"main": "./src/App.ts",
	"scripts": {
		"dev": "nodemon",
		"build": "rimraf ./build && tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
		"start": "node ./build/src/App.js",
		"check-types": "tsc --noEmit",
		"lint": "eslint .",
		"inspect": "nodemon --inspect ./src/App.ts"
	},
	"dependencies": {
		"@asteasolutions/zod-to-openapi": "^8.4.0",
		"@pluteojs/api-types": "workspace:*",
		"@pluteojs/better-auth": "workspace:*",
		"@pluteojs/database": "workspace:*",
		"@pluteojs/email-templates": "workspace:*",
		"@pluteojs/types": "^0.1.2",
		"argon2": "^0.41.1",
		"better-auth": "^1.2.8",
		"cors": "^2.8.5",
		"dotenv": "^16.5.0",
		"express": "^5.1.0",
		"express-jwt": "^8.5.1",
		"form-data": "^4.0.2",
		"helmet": "^8.1.0",
		"http-errors": "^2.0.0",
		"jsonwebtoken": "^9.0.2",
		"mailgun.js": "^12.0.1",
		"moment-timezone": "^0.5.48",
		"ms": "^2.1.3",
		"nanoid": "^5.1.5",
		"nodemailer": "^6.10.1",
		"qs": "^6.14.0",
		"winston": "^3.17.0",
		"winston-slack-webhook-transport": "^2.3.6",
		"zod": "^4.3.5"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix"
		]
	},
	"devDependencies": {
		"@pluteojs/eslint-config": "workspace:*",
		"@pluteojs/typescript-config": "workspace:*",
		"@scalar/express-api-reference": "^0.8.34",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.1",
		"@types/http-errors": "^2.0.4",
		"@types/jsonwebtoken": "^9.0.9",
		"@types/ms": "^2.1.0",
		"@types/node": "^22.14.1",
		"@types/nodemailer": "^6.4.17",
		"copyfiles": "^2.4.1",
		"nodemon": "^3.1.9",
		"rimraf": "^6.0.1",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.10",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.2"
	}
}
