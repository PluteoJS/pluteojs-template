{
	"name": "@pluteojs/email-templates",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "email dev -p 3001 --dir src/emailTemplates",
		"dev:auth": "email dev -p 3001 --dir src/emailTemplates/auth",
		"dev:transactional": "email dev -p 3001 --dir src/emailTemplates/transactional",
		"dev:marketing": "email dev -p 3001 --dir src/emailTemplates/marketing",
		"build": "tsup",
		"check-types": "tsc --noEmit",
		"lint": "eslint ."
	},
	"dependencies": {
		"@react-email/components": "^1.0.1",
		"@react-email/render": "^2.0.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@pluteojs/eslint-config": "workspace:*",
		"@pluteojs/typescript-config": "workspace:*",
		"@react-email/preview-server": "5.0.5",
		"@types/react": "^19.1.6",
		"react-email": "^5.0.5",
		"tsup": "^8.4.0",
		"typescript": "^5.9.2"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix"
		]
	}
}
