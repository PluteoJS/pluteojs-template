{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@pluteojs/typescript-config/react-library.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"declaration": true,
		"declarationMap": true,
		"module": "ESNext",
		"moduleResolution": "Bundler"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
