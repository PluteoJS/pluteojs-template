{
	"name": "@pluteojs/api-types",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"check-types": "tsc --noEmit",
		"lint": "eslint .",
		"dev": "tsup --watch"
	},
	"dependencies": {
		"zod": "^3.24.4"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix"
		]
	},
	"devDependencies": {
		"@pluteojs/eslint-config": "workspace:*",
		"@pluteojs/typescript-config": "workspace:*",
		"tsup": "^8.4.0",
		"typescript": "^5.9.2"
	}
}
