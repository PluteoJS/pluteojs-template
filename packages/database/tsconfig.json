{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@pluteojs/typescript-config/base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"declaration": true,
		"declarationMap": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "drizzle"]
}
