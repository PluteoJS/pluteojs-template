{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@pluteojs/typescript-config/base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"declaration": true,
		"declarationMap": true,
		"baseUrl": "./src",
		"paths": {
			"@/*": ["*", "*.ts", "*/index.ts"]
		}
	},
	"include": ["src", "drizzle.config.ts"],
	"exclude": ["node_modules", "dist", "drizzle"]
}
