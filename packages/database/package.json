{
	"name": "@pluteojs/database",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./schema": {
			"types": "./dist/schema/index.d.ts",
			"import": "./dist/schema/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"check-types": "tsc --noEmit",
		"lint": "eslint .",
		"dev": "tsup --watch",
		"db:drizzle": "tsx node_modules/drizzle-kit/bin.cjs --config ./drizzle.config.ts",
		"db:generate": "pnpm db:drizzle generate",
		"db:migrate": "pnpm db:drizzle migrate",
		"db:push": "pnpm db:drizzle push",
		"db:studio": "pnpm db:drizzle studio"
	},
	"dependencies": {
		"dotenv": "^16.5.0",
		"drizzle-orm": "^0.38.2",
		"pg": "^8.13.1",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@pluteojs/eslint-config": "workspace:*",
		"@pluteojs/typescript-config": "workspace:*",
		"@types/pg": "^8.11.10",
		"drizzle-kit": "^0.30.1",
		"tsup": "^8.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.2"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix"
		]
	}
}
