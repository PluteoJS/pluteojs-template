{
	"name": "@pluteojs/better-auth",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./util": {
			"types": "./dist/util/index.d.ts",
			"import": "./dist/util/index.js"
		},
		"./cli": {
			"types": "./dist/auth.cli.d.ts",
			"import": "./dist/auth.cli.js"
		}
	},
	"scripts": {
		"build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist",
		"check-types": "tsc --noEmit",
		"lint": "eslint .",
		"dev": "tsup --watch",
		"better-auth:generate": "pnpm dlx @better-auth/cli generate --config ./src/auth.cli.ts --output ../database/src/schema/betterAuth/betterAuth.schema.ts --yes"
	},
	"dependencies": {
		"@pluteojs/database": "workspace:*",
		"@pluteojs/email-templates": "workspace:*",
		"@react-email/render": "^1.0.3",
		"better-auth": "^1.2.8",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@pluteojs/eslint-config": "workspace:*",
		"@pluteojs/typescript-config": "workspace:*",
		"tsup": "^8.4.0",
		"typescript": "^5.9.2"
	},
	"peerDependencies": {
		"@pluteojs/database": "workspace:*"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint --fix"
		]
	}
}
