{
	"name": "pluteo-js",
	"version": "0.0.1",
	"description": "PluteoJS Server",
	"main": "./src/App.ts",
	"repository": "git@gitlab.com:PluteoJS/pluteojs-template.git",
	"author": "Muhammad Swalah A A <swalah@heedlabs.com>",
	"private": true,
	"packageManager": "yarn@4.9.0",
	"scripts": {
		"check-types": "tsc --noemit",
		"eslint": "eslint . --ext .js,.jsx,.ts,.tsx",
		"lint": "yarn eslint && yarn check-types",
		"format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
		"start:dev": "nodemon",
		"copy-to-build:sql": "copyfiles -u 1 \"./src/**/*.sql\" \"build/src\"",
		"build": "rimraf ./build && tsc --project tsconfig.json && tsconfig-replace-paths -p tsconfig.json -s ./ -o ./build && yarn copy-to-build:sql",
		"start:production": "yarn build && node ./build/src/App.js",
		"inspect": "nodemon --inspect ./src/App.ts",
		"bump-version": "npm version --no-git-tag-version",
		"get-next-version": "ts-node ./.standard-version/commands/ComputeNextVersion.ts",
		"release-branch": "git flow release start $(ts-node ./.standard-version/commands/ComputeNextVersion.ts)",
		"release": "standard-version"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"standard-version": {
		"skip": {
			"tag": true
		},
		"scripts": {
			"postcommit": "ts-node ./.standard-version/commands/FixGitFlowReleaseBranchName.ts"
		}
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.0",
		"@commitlint/config-conventional": "^19.8.0",
		"@eslint/compat": "^1.2.8",
		"@eslint/eslintrc": "^3.3.1",
		"@eslint/js": "^9.24.0",
		"@types/conventional-recommended-bump": "^6.1.1",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.1",
		"@types/http-errors": "^2.0.4",
		"@types/joi": "^17.2.3",
		"@types/jsonwebtoken": "^9.0.9",
		"@types/ms": "^2.1.0",
		"@types/node": "^22.14.1",
		"@types/nodemailer": "^6.4.17",
		"@types/semver": "^7.7.0",
		"@types/shelljs": "^0.8.15",
		"@typescript-eslint/eslint-plugin": "^8.29.1",
		"@typescript-eslint/parser": "^8.29.1",
		"conventional-recommended-bump": "^6.1.0",
		"copyfiles": "^2.4.1",
		"eslint": "^9.24.0",
		"eslint-config-prettier": "^10.1.2",
		"eslint-import-resolver-typescript": "^4.3.2",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-prettier": "^5.2.6",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.1",
		"nodemon": "^3.1.9",
		"prettier": "^3.5.3",
		"rimraf": "^6.0.1",
		"semver": "^7.7.1",
		"shelljs": "^0.9.2",
		"simple-git": "^3.27.0",
		"standard-version": "^9.5.0",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsconfig-replace-paths": "^0.0.14",
		"typescript": "5.8.3"
	},
	"dependencies": {
		"@pluteojs/types": "^0.1.2",
		"argon2": "^0.41.1",
		"celebrate": "^15.0.3",
		"cors": "^2.8.5",
		"dotenv": "^16.5.0",
		"express": "^5.1.0",
		"express-jwt": "^8.5.1",
		"form-data": "^4.0.2",
		"helmet": "^8.1.0",
		"http-errors": "^2.0.0",
		"joi": "^17.13.3",
		"jsonwebtoken": "^9.0.2",
		"mailgun.js": "^12.0.1",
		"moment-timezone": "^0.5.48",
		"ms": "^2.1.3",
		"nanoid": "^3.3.11",
		"nodemailer": "^6.10.1",
		"pg-monitor": "^3.0.0",
		"pg-promise": "^11.13.0",
		"qs": "^6.14.0",
		"winston": "^3.17.0",
		"winston-slack-webhook-transport": "^2.3.6"
	},
	"volta": {
		"node": "22.14.0",
		"yarn": "4.9.0"
	}
}
