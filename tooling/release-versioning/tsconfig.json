{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@pluteojs/typescript-config/base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"declaration": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
